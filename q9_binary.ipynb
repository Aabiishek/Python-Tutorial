      "cell_type": "code",
      "source": [
        "binary = input(\"Enter binary number: \")\n",
        "decimal = 0\n",
        "power = 0\n",
        "\n",
        "for digit in binary[::-1]:\n",
        "    decimal += int(digit) * (2 ** power)\n",
        "    power += 1\n",
        "\n",
        "print(\"Decimal:\", decimal)"
      ],
